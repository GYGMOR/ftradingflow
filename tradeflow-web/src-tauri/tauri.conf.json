{
  "productName": "TradeFlow",
  "version": "1.0.0",
  "identifier": "io.tradeflow.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TradeFlow",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
      "active": true,
      "targets": ["nsis", "appimage", "deb"],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "nsis": {
          "create_desktop_shortcut": true,
          "create_start_menu_shortcut": true
        }
      },
      "externalBin": []
    }
}
